---
/* Fully self-contained component */
---

<section class="contact-section home-section">
  <style>
    .contact-section {
      padding: var(--space-2xl) 0;
      background: transparent;
      display: flex;
      justify-content: center;
    }

    .contact-box {
      background: var(--clay-gradient);
      border: none;
      border-radius: var(--radius-clay);
      padding: 3rem 2rem;
      max-width: 750px;
      width: 100%;
      text-align: center;
      box-shadow: var(--clay-shadow);
    }

    .contact-heading {
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
    }

    .contact-subtitle {
      font-size: 1.05rem;
      color: var(--color-text-secondary);
      margin-bottom: 2.5rem;
    }

    /* THREE OPTIONS IN ONE ROW */
    .contact-row {
      display: flex;
      justify-content: space-between;
      gap: 1.5rem;
      margin-top: 1rem;
    }

    .contact-item {
      flex: 1;
      background: var(--clay-gradient);
      border: none;
      border-radius: var(--radius-clay);
      padding: 1.2rem;
      text-decoration: none;
      color: var(--color-text);
      display: flex;
      flex-direction: column;
      align-items: center;
      box-shadow: var(--clay-shadow);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .contact-item:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: var(--clay-shadow-hover);
    }

    .contact-icon {
      width: 32px;
      height: 32px;
      margin-bottom: 0.75rem;
    }

    .contact-label {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .contact-value {
      font-size: 0.95rem;
      color: var(--color-text-secondary);
    }

    @media (max-width: 700px) {
      .contact-row {
        flex-direction: column;
      }
    }
  </style>

  <div class="contact-box">

    <h2 class="contact-heading">Have Questions? Ask Our Team</h2>
    <p class="contact-subtitle">
      Want to contact us directly? No problem. We are always here for you.
    </p>

    <div class="contact-row">

      <!-- LIVE CHAT -->
      <a href="https://m.me/marsalaccountants" class="contact-item">
        <svg class="contact-icon" viewBox="0 0 24 24" fill="var(--color-primary)">
          <path d="M12 2C6.48 2 2 6.02 2 11c0 2.63 1.2 5 3.2 6.7V22l3.5-1.9c1 .3 2.1.5 3.3.5 5.52 0 10-4.02 10-9s-4.48-9-10-9z"/>
        </svg>
        <div class="contact-label">Live Chat</div>
        <div class="contact-value">Messenger Support</div>
      </a>

      <!-- CALL US -->
      <a href="tel:07468641272" class="contact-item">
        <svg class="contact-icon" viewBox="0 0 24 24" fill="var(--color-primary)">
          <path d="M6.6 10.8c1.2 2.4 3.2 4.4 5.6 5.6l1.9-1.9c.3-.3.8-.4 1.2-.3 1.3.4 2.7.6 4.1.6.7 0 1.3.6 1.3 1.3V21c0 .7-.6 1.3-1.3 1.3C10.4 22.3 1.7 13.6 1.7 2.3 1.7 1.6 2.3 1 3 1h3.3c.7 0 1.3.6 1.3 1.3 0 1.4.2 2.8.6 4.1.1.4 0 .9-.3 1.2l-1.9 1.9z"/>
        </svg>
        <div class="contact-label">Call Us</div>
        <div class="contact-value">074‑6864‑1272</div>
      </a>

      <!-- WHATSAPP -->
      <a href="https://wa.me/447468641272" class="contact-item">
        <svg class="contact-icon" viewBox="0 0 24 24" fill="#25D366">
          <path d="M12 2C6.5 2 2 6.3 2 11.7c0 2.1.7 4 1.9 5.6L3 22l4.9-1.6c1.2.4 2.3.6 3.5.6 5.5 0 10-4.3 10-9.7C21.4 6.3 17 2 12 2zm5.3 14.2c-.2.6-1.2 1.1-1.7 1.2-.5.1-1 .1-1.6-.1-.4-.1-1-.3-1.7-.6-3-1.3-5-4.3-5.2-4.5-.2-.3-1.2-1.6-1.2-3s.8-2.1 1.1-2.4c.3-.3.7-.4 1-.4h.7c.2 0 .5 0 .7.6.3.7 1 2.4 1.1 2.6.1.2.1.4 0 .6-.1.2-.2.4-.4.6-.2.2-.4.5-.6.7-.2.2-.4.4-.2.8.2.4 1 1.6 2.1 2.6 1.4 1.2 2.6 1.6 3 .8.3-.5.7-.8 1.1-1.2.2-.2.4-.3.6-.2.2.1 1.5.7 1.7.8.2.1.4.2.5.3.1.1.1.7-.1 1.3z"/>
        </svg>
        <div class="contact-label">WhatsApp</div>
        <div class="contact-value">+44 785 833 6199</div>
      </a>

    </div>

  </div>
</section>

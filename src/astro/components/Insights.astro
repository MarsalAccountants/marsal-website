---
import "../../styles/components/insight.css";
---

<section class="insights-section home-section">
  <div class="container">

    <div class="insights-grid">

      <!-- About Us (merged Company Profile + Philosophy) -->
      <article class="insight-card">
        <a href="http://localhost:4321/company-profiles/" class="insight-image">
          <img src="https://marsalaccountants.co.uk/wp-content/uploads/2025/06/w1.jpg" alt="About Marsal Accountants">
        </a>
        <div class="insight-content">
          <h3>Who We Are</h3>
          <p>
            Learn about Marsal Accountants — our background, philosophy, and how we support
            individuals and businesses across Paisley, Glasgow, and Scotland.
          </p>
          <a href="http://localhost:4321/company-profiles/" class="insight-link">
            Learn more →
          </a>
        </div>
      </article>

      <!-- Tax Tables -->
      <article class="insight-card">
        <a href="http://localhost:4321/resources/tax-tables" class="insight-image">
          <img src="https://marsalaccountants.co.uk/wp-content/uploads/2025/06/w3.jpg" alt="UK tax tables and rates">
        </a>
        <div class="insight-content">
          <h3>Tax Tables</h3>
          <p>
            Access current UK tax rates and thresholds to help you understand
            your tax position and financial obligations.
          </p>
          <a href="http://localhost:4321/resources/tax-tables" class="insight-link">
            View tax tables →
          </a>
        </div>
      </article>

    </div>
  </div>
</section>

---
import "../../styles/components/insight.css";
---

<section class="insights-section home-section">
  <div class="container">

    <div class="insights-grid">

      <!-- About Us (merged Company Profile + Philosophy) -->
      <article class="insight-card">
        <a href="/company-profiles/" class="insight-image insight-image--who-we-are">
          <img src="/images/who-we-are.jpg" alt="About Marsal Accountants" width="800" height="450" loading="lazy" decoding="async">
        </a>
        <div class="insight-content">
          <h3>Who We Are</h3>
          <p>
            Learn about Marsal Accountants — our background, philosophy, and how we support
            individuals and businesses across Paisley, Glasgow, and Scotland.
          </p>
          <a href="/company-profiles/" class="insight-link">
            Learn more →
          </a>
        </div>
      </article>

      <!-- Tax Tables -->
      <article class="insight-card">
        <a href="/resources/tax-tables/" class="insight-image insight-image--tax-tables">
          <img src="/images/tax-tables.avif" alt="UK tax tables and rates" width="800" height="450" loading="lazy" decoding="async">
        </a>
        <div class="insight-content">
          <h3>Tax Tables</h3>
          <p>
            Access current UK tax rates and thresholds to help you understand
            your tax position and financial obligations.
          </p>
          <a href="/resources/tax-tables/" class="insight-link">
            View tax tables →
          </a>
        </div>
      </article>

    </div>
  </div>
</section>

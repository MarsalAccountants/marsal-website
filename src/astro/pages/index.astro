<!doctype html>
---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import WelcomeText from "../components/WelcomeText.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Insights from "../components/Insights.astro";
import About from "../components/About.astro";
import Reviews from "../components/Reviews.astro";
import PricingAccounts from "../components/PricingAccounts.astro";
import ContactUs from "../components/ContactUs.astro";
---

<BaseLayout
  title="Accountants in Paisley | Marsal Accountants"
  description="Professional accountants in Paisley, Glasgow and Central Scotland. Tax returns, bookkeeping, payroll, VAT and business advice. Free consultation."
>

  <!-- HERO appears directly under the header -->
  <Hero slot="hero" />

  <WelcomeText />

  <ServiceCard />

  <Insights />

  <About />

  <Reviews />

  <PricingAccounts />

  <ContactUs />

</BaseLayout>

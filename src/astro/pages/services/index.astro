---
// D:\Marsals\website\src\pages\services.astro

import "../../../styles/pages/services/services.css";
import Layout from "../../layouts/BaseLayout.astro";
import ContactUs from "../../components/ContactUs.astro";
---

<Layout title="Accounting Services in Paisley | Marsal Accountants">
  <main class="services-page">

    <section class="services-container">

      <!-- PAGE HEADING -->
      <h1 class="services-heading">Professional Accounting Services in Paisley</h1>
      <div class="section-divider"></div>

      <!-- INTRO -->
      <p class="services-lead">
        Marsal Accountants provides reliable, modern, and client‑focused accounting services to individuals,
        landlords, sole traders, and companies across <strong>Paisley</strong> and wider Scotland.
        Our goal is simple: to give you clarity, confidence, and complete peace of mind in your accounts and tax affairs.
      </p>

      <p class="services-lead">
        Explore our full range of services below — each designed to support your business, reduce stress,
        and help you make informed financial decisions.
      </p>

      <!-- SERVICES LIST -->
      <div class="services-list">

        <!-- SERVICE ITEM -->
        <div class="service-row">
          <img src="/images/Accounting-Services-paisley.jpg" alt="Accounting Services Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/accounting/">Accounting Services</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Full annual accounts preparation for sole traders, partnerships, and limited companies.
              Clear, accurate, and compliant — helping you understand your financial position with confidence.
            </p>
            <a href="/services/accounting/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/Bookkeeping-Services-paisley.jpg" alt="Bookkeeping Services Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/bookkeeping/">Bookkeeping Services</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Accurate, organised bookkeeping that keeps your business running smoothly.
              Ideal for small businesses and self‑employed clients across Paisley.
            </p>
            <a href="/services/bookkeeping/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/management-accounts-paisley.jpg" alt="Management Accounts Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/management-accounts/">Management Accounts</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Monthly or quarterly management accounts to help you track performance,
              manage cashflow, and make informed business decisions.
            </p>
            <a href="/services/management-accounts/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/payroll-services-paisley.jpg" alt="Payroll Services Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/payroll/">Payroll Services</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Fast, accurate payroll with payslips delivered within 24 hours.
              Includes expert guidance on employment law and HMRC compliance.
            </p>
            <a href="/services/payroll/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/property-accounts-paisley.jpg" alt="Property Accounts Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/property-accounts/">Property Accounts</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Specialist support for landlords and property investors.
              Maximise your rental income and stay fully compliant with HMRC.
            </p>
            <a href="/services/property-accounts/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/self-assessment-paisley.jpg" alt="Self Assessment Tax Returns Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/self-assessment-tax-returns/">Self‑Assessment Tax Returns</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Avoid penalties and reduce your tax bill with expert tax return preparation.
              Perfect for self‑employed individuals, landlords, and high‑income earners.
            </p>
            <a href="/services/self-assessment-tax-returns/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/corporation-tax-paisley.jpg" alt="Corporation Tax Return Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/corporation-tax-return-services/">Corporation Tax Returns</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Complete corporation tax support for limited companies.
              We handle submissions, planning, and compliance — so you can focus on growth.
            </p>
            <a href="/services/corporation-tax-return-services/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/new-business-paisley.jpg" alt="New Business Setup Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/business-setup/">Starting a New Business</a></h2>
            <div class="divider-content-small"></div>
            <p>
              From business structure to budgeting, we help new businesses in Paisley
              start strong with the right financial foundations.
            </p>
            <a href="/services/business-setup/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/tax-investigation-services-paisley.jpg" alt="Tax Investigation Support Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/tax-investigation/">Tax Investigation Support</a></h2>
            <div class="divider-content-small"></div>
            <p>
              Facing an HMRC enquiry? Our experienced tax consultants provide
              expert guidance and full representation for complete peace of mind.
            </p>
            <a href="/services/tax-investigation/" class="btn-more">Read More</a>
          </div>
        </div>

        <div class="service-row">
          <img src="/images/vat-return-services-paisley.jpg" alt="VAT Services Paisley" class="service-img" loading="lazy" />
          <div>
            <h2 class="service-title"><a href="/services/vat/">VAT Services</a></h2>
            <div class="divider-content-small"></div>
            <p>
              VAT registration, filing, and planning — ensuring your business stays compliant
              while choosing the most tax‑efficient VAT scheme.
            </p>
            <a href="/services/vat/" class="btn-more">Read More</a>
          </div>
        </div>

      </div>

    </section>

    <!-- Contact Us Component -->
    <ContactUs />

  </main>

  <!-- Scroll Reveal Animation -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const serviceRows = document.querySelectorAll(".service-row");
      
      if (!("IntersectionObserver" in window)) {
        serviceRows.forEach(row => row.classList.add("in-view"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.classList.add("in-view");
              }, index * 120);
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
      );

      serviceRows.forEach(row => observer.observe(row));
    });
  </script>
</Layout>
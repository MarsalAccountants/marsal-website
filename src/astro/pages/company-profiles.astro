---
import "../../styles/pages/company-profiles.css";
import Layout from "../layouts/BaseLayout.astro";
import ContactUs from "../components/ContactUs.astro";
---

<Layout title="About Us | Marsal Accountants">
  <main class="about-page">


    <!-- ========================= -->
    <!-- SECTION 1: OUR PHILOSOPHY -->
    <!-- ========================= -->
    <section class="about-section">
      <h1 class="about-heading">Our Philosophy</h1>
      <div class="about-divider"></div>

      <p class="about-lead">
        At <span class="mg">Marsal Accountants</span>, our philosophy is simple: 
        to give every client clarity, confidence, and genuine care in all areas of their accounts and tax affairs.
      </p>

      <div class="about-grid philosophy-grid">
        <div class="about-image-wrapper">
          <img 
            src="/images/marsal-accountants-director.PNG" 
            alt="Director of Marsal Accountants"
            class="about-image"
            loading="lazy"
          />
          <div class="about-caption"><span class="mg">Marsal Accountants</span> Director</div>
        </div>

        <div class="about-text philosophy-text">
          <h2 class="about-subheading">Director's Vision</h2>

          <p>
            My vision for <span class="mg">Marsal</span> has always been clear: to build an accounting firm that feels modern, 
            precise, and genuinely supportive. Accounting should not feel distant or complicated — it should 
            feel like a partnership built on trust.
          </p>

          <p>
            We support hardworking business owners across Paisley, Glasgow, and Scotland. They deserve 
            accountants who understand their challenges, speak their language, and guide them with honesty 
            and accuracy.
          </p>

          <p>
            Every return we file and every set of accounts we prepare is guided by one principle: 
            <strong>your success is our responsibility.</strong>
          </p>
        </div>
      </div>

      <!-- VALUES GRID -->
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon"><i class="fas fa-lightbulb"></i></div>
          <h3 class="value-title">Clarity Above Everything</h3>
          <p class="value-text">
            We explain your accounts and tax position in simple, direct language — so you always know where you stand.
          </p>
        </div>

        <div class="value-card">
          <div class="value-icon"><i class="fas fa-check-circle"></i></div>
          <h3 class="value-title">Precision You Can Trust</h3>
          <p class="value-text">
            Every figure, return, and deadline is handled with accuracy, discipline, and professional care.
          </p>
        </div>

        <div class="value-card">
          <div class="value-icon"><i class="fas fa-gears"></i></div>
          <h3 class="value-title">Modern Systems, Human Support</h3>
          <p class="value-text">
            We use efficient digital resources, but our service is always personal, accessible, and built around real relationships.
          </p>
        </div>
      </div>
    </section>

        <!-- ========================= -->
    <!-- SECTION 2: COMPANY PROFILE -->
    <!-- ========================= -->
    <section class="about-section">
      <h1 class="about-heading">Company Profile</h1>
      <div class="about-divider"></div>

      <p class="about-lead">
        With over eight years of experience and a modern, client‑first approach, 
        <strong><span class="mg">Marsal Accountants</span></strong> provides tailored accounting and tax solutions 
        to businesses and individuals across the UK.
      </p>

      <div class="company-profile-content">
        <div class="profile-text-above">
          <p>
            We specialise in Business Accounts, Tax Returns, VAT, Payroll, Bookkeeping, and advisory services 
            for Sole Traders, Partnerships, LLPs, Limited Companies, and PLCs.
          </p>
        </div>

        <div class="profile-image-center">
          <img 
            src="/images/marsal-accountants-about-us.png" 
            alt="Marsal Accountants About Us"
            class="profile-center-image"
            loading="lazy"
          />
          <div class="about-caption">Supporting clients across Scotland</div>
        </div>

        <div class="profile-strength-clients">
          <div class="strength-clients-grid">
            <!-- LEFT COLUMN: OUR STRENGTH -->
            <div class="strength-section">
              <h2 class="about-subheading">Our Strength</h2>
              <p>
                Our strength lies in strategic insight, attention to detail, and meaningful client relationships. 
                We help businesses stay compliant, understand their numbers, and plan with confidence.
              </p>
            </div>
            
            <!-- RIGHT COLUMN: WHO WE SERVE -->
            <div class="clients-section">
              <h2 class="about-subheading">Who We Serve</h2>
              <div class="clients-box">
                <h3>Our Clients Range From:</h3>
                <div class="clients-list">
                  <div class="client-item">
                    <div class="client-checkmark"><i class="fas fa-check"></i></div>
                    <div class="client-text">Doctors, Dentists, Solicitors to Opticians, Pharmacies, and Estate Agencies</div>
                  </div>
                  <div class="client-item">
                    <div class="client-checkmark"><i class="fas fa-check"></i></div>
                    <div class="client-text">Hotels, Pubs, Restaurants to Subways, Papa Johns, and Cafés</div>
                  </div>
                  <div class="client-item">
                    <div class="client-checkmark"><i class="fas fa-check"></i></div>
                    <div class="client-text">Supermarkets, Convenience Stores, Office licenses to Furniture and Mobile Phone retailers</div>
                  </div>
                  <div class="client-item">
                    <div class="client-checkmark"><i class="fas fa-check"></i></div>
                    <div class="client-text">Retailers, Wholesalers, Importers, Exporters, Distributors, and Logistics companies</div>
                  </div>
                  <div class="client-item">
                    <div class="client-checkmark"><i class="fas fa-check"></i></div>
                    <div class="client-text">Electricians, Plumbers, Carpenters to Management Consultants and IT Professionals</div>
                  </div>
                  <div class="client-item">
                    <div class="client-checkmark"><i class="fas fa-check"></i></div>
                    <div class="client-text">Travel Agents, Residential Homes, Hair Salons, Launderettes, and Charities</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Contact Us Component -->
    <ContactUs />

  </main>

  <!-- Scroll Reveal Animation -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const cards = document.querySelectorAll(".value-card, .about-image-wrapper, .about-text, .profile-image-center, .profile-text-above, .profile-text-below");
      if (!("IntersectionObserver" in window)) {
        cards.forEach(card => card.classList.add("in-view"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.classList.add("in-view");
              }, index * 120);
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
      );

      cards.forEach(card => observer.observe(card));
    });
  </script>
</Layout>
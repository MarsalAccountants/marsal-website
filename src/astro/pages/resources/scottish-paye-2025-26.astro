  <!-- CONTACT US COMPONENT (if needed) -->
  <ContactUs />

  <!-- Inline CSS for calculator-specific fixes -->
  <style>
    /* Fix for results card display issues */
    #payeResults {
        display: none;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    }
    
    #payeResults.show-results {
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
    }
    
    /* Ensure no other CSS interferes */
    .calculator-grid .calculator-card {
        display: block !important;
    }
    
    .results-card {
        position: relative !important;
        z-index: 10 !important;
    }
    
    /* Form validation styles */
    .error {
        border-color: var(--color-danger) !important;
        background-color: var(--color-danger-soft) !important;
    }
    
    .error-message {
        color: var(--color-danger);
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }
    
    /* Loading animation */
    .loading-spinner {
        display: none;
    }
    
    .loading-spinner.active {
        display: inline-block;
        margin-right: 8px;
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script is:inline>
    // PAYE Calculator Logic
    const Marsal = {
        initializeCalculator: function() {
            if (window.__marsalPayeInitialized) return;
            window.__marsalPayeInitialized = true;

            // Initialize accordion
            const accordionBtn = document.getElementById('additionalOptionsBtn');
            if (accordionBtn) {
                accordionBtn.addEventListener('click', this.toggleAccordion);
            }
            
            // Initialize pension toggle
            const pensionToggle = document.getElementById('pensionToggle');
            if (pensionToggle) {
                pensionToggle.addEventListener('change', this.togglePension);
            }
            
            // Initialize calculate button
            const calculateBtn = document.getElementById('calculateBtn');
            if (calculateBtn) {
                calculateBtn.addEventListener('click', this.calculatePAYE);
            }
            
            // Initialize print button
            const printBtn = document.getElementById('printResultsBtn');
            if (printBtn) {
                printBtn.addEventListener('click', this.printResults);
            }
            
            // Initialize reset button
            const resetBtn = document.getElementById('resetCalculatorBtn');
            if (resetBtn) {
                resetBtn.addEventListener('click', this.resetCalculator);
            }
            
            // Initialize carousel
            this.initializeCarousel();
            
            // Hide results card initially
            const resultsCard = document.getElementById('payeResults');
            if (resultsCard) {
                resultsCard.style.display = 'none';
                resultsCard.style.opacity = '0';
                resultsCard.style.visibility = 'hidden';
            }
        },
        
        toggleAccordion: function(event) {
            const btn = event.currentTarget;
            const item = btn.closest('.accordion-item');
            if (item) item.classList.toggle('open');
        },
        
        togglePension: function() {
            const pensionInput = document.getElementById('pensionInput');
            const pensionToggle = document.getElementById('pensionToggle');
            
            if (pensionToggle.checked) {
                pensionInput.style.display = 'block';
            } else {
                pensionInput.style.display = 'none';
            }
        },
        
        calculatePAYE: function(event) {
            event.preventDefault();
            const btn = event.currentTarget;
            const spinner = btn.querySelector('.loading-spinner');
            
            // Show loading spinner
            spinner.classList.add('active');
            btn.disabled = true;
            
            // Simulate calculation delay
            setTimeout(() => {
                // Get form values
                const grossSalary = parseFloat(document.getElementById('gross').value) || 0;
                const taxCode = document.getElementById('tax_code').value;
                const niCategory = document.getElementById('ni_category').value;
                const pensionToggle = document.getElementById('pensionToggle').checked;
                const pensionPercent = parseFloat(document.getElementById('pensionPercent').value) || 0;
                const studentLoanToggle = document.getElementById('studentLoanToggle').checked;
                
                // Calculate PAYE (simplified for demo)
                const personalAllowance = 12570;
                const taxableIncome = Math.max(0, grossSalary - personalAllowance);
                
                // Scottish tax bands 2025-26
                const taxBands = [
                    { limit: 2306, rate: 0.19 },
                    { limit: 14322, rate: 0.20 },
                    { limit: 31092, rate: 0.21 },
                    { limit: 62430, rate: 0.42 },
                    { limit: Infinity, rate: 0.47 }
                ];
                
                let remainingTaxable = taxableIncome;
                let totalTax = 0;
                
                taxBands.forEach((band, index) => {
                    const previousLimit = index === 0 ? 0 : taxBands[index - 1].limit;
                    const bandWidth = band.limit - previousLimit;
                    
                    if (remainingTaxable > 0) {
                        const taxableInBand = Math.min(remainingTaxable, bandWidth);
                        totalTax += taxableInBand * band.rate;
                        remainingTaxable -= taxableInBand;
                    }
                });
                
                // National Insurance calculation (simplified)
                const niPrimaryThreshold = 12570;
                const niUpperLimit = 50270;
                let niContribution = 0;
                
                if (grossSalary > niPrimaryThreshold) {
                    const niLowerBand = Math.min(grossSalary, niUpperLimit) - niPrimaryThreshold;
                    const niUpperBand = Math.max(0, grossSalary - niUpperLimit);
                    
                    niContribution = (niLowerBand * 0.12) + (niUpperBand * 0.02);
                }
                
                // Pension calculation
                let pensionContribution = 0;
                if (pensionToggle && pensionPercent > 0) {
                    pensionContribution = grossSalary * (pensionPercent / 100);
                }
                
                // Student loan calculation
                let studentLoan = 0;
                const studentLoanThreshold = 24275;
                if (studentLoanToggle && grossSalary > studentLoanThreshold) {
                    studentLoan = (grossSalary - studentLoanThreshold) * 0.09;
                }
                
                // Calculate totals
                const totalDeductions = totalTax + niContribution + pensionContribution + studentLoan;
                const netAnnual = grossSalary - totalDeductions;
                
                // Get frequency
                const frequency = document.querySelector('input[name="frequency"]:checked').value;
                let netFrequency = 0;
                let frequencyLabel = '';
                let frequencyText = '';
                
                switch(frequency) {
                    case 'monthly':
                        netFrequency = netAnnual / 12;
                        frequencyLabel = 'Monthly Take-Home';
                        frequencyText = 'Per month';
                        break;
                    case 'weekly':
                        netFrequency = netAnnual / 52;
                        frequencyLabel = 'Weekly Take-Home';
                        frequencyText = 'Per week';
                        break;
                    case 'annual':
                        netFrequency = netAnnual;
                        frequencyLabel = 'Annual Take-Home';
                        frequencyText = 'Per year';
                        break;
                }
                
                // Update results display
                document.getElementById('netResult').textContent = `£${netAnnual.toFixed(2)}`;
                document.getElementById('monthlyResult').textContent = `£${netFrequency.toFixed(2)}`;
                document.getElementById('frequencyLabel').textContent = frequencyLabel;
                document.getElementById('frequencyText').textContent = frequencyText;
                document.getElementById('taxResult').textContent = `£${totalTax.toFixed(2)}`;
                document.getElementById('niResult').textContent = `£${niContribution.toFixed(2)}`;
                document.getElementById('niCategoryLabel').textContent = `Category ${niCategory}`;
                document.getElementById('pensionResult').textContent = `£${pensionContribution.toFixed(2)}`;
                document.getElementById('pensionRateLabel').textContent = `${pensionPercent}%`;
                document.getElementById('studentLoanResult').textContent = `£${studentLoan.toFixed(2)}`;
                document.getElementById('deductionsResult').textContent = `£${totalDeductions.toFixed(2)}`;
                
                // Update tax breakdown
                const taxBreakdown = document.getElementById('taxBreakdown');
                taxBreakdown.innerHTML = `
                    <div class="tax-band-item">
                        <div class="tax-band-label">Personal Allowance</div>
                        <div class="tax-band-value">£${Math.min(grossSalary, personalAllowance).toFixed(2)}</div>
                        <div class="tax-band-rate">0%</div>
                    </div>
                    <div class="tax-band-item">
                        <div class="tax-band-label">Taxable Income</div>
                        <div class="tax-band-value">£${taxableIncome.toFixed(2)}</div>
                        <div class="tax-band-rate">Various</div>
                    </div>
                `;
                
                // Show results card
                const resultsCard = document.getElementById('payeResults');
                if (resultsCard) {
                    resultsCard.style.display = 'block';
                    setTimeout(() => {
                        resultsCard.classList.add('show-results');
                    }, 10);
                }
                
                // Hide loading spinner
                spinner.classList.remove('active');
                btn.disabled = false;
                
                Marsal.initializeChart({
                    tax: totalTax,
                    ni: niContribution,
                    pension: pensionContribution,
                    studentLoan: studentLoan,
                    net: netAnnual
                });
                
            }, 800);
        },
        
        initializeChart: function(data) {
            if (typeof Chart === 'undefined') return;
            const canvas = document.getElementById('taxChart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');

            if (window.payeChart) {
                window.payeChart.destroy();
            }

            window.payeChart = new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: ['Income Tax', 'National Insurance', 'Pension', 'Student Loan', 'Take-Home Pay'],
                    datasets: [{
                        data: [data.tax, data.ni, data.pension, data.studentLoan, data.net],
                        backgroundColor: [
                            '#ff6384',
                            '#36a2eb',
                            '#ffce56',
                            '#4bc0c0',
                            '#9966ff'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    animation: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const label = context.label || '';
                                    const value = context.raw || 0;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total ? Math.round((value / total) * 100) : 0;
                                    return `${label}: £${value.toFixed(2)} (${percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });
        },
        
        printResults: function() {
            const resultsCard = document.getElementById('payeResults');
            if (!resultsCard || !resultsCard.classList.contains('show-results')) return;

            document.body.classList.add('paye-print-results');

            const cleanup = function() {
                document.body.classList.remove('paye-print-results');
                window.removeEventListener('afterprint', cleanup);
                clearTimeout(fallbackTimer);
            };
            const fallbackTimer = setTimeout(cleanup, 5000);
            window.addEventListener('afterprint', cleanup);

            requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                    window.print();
                });
            });
        },
        
        resetCalculator: function() {
            // Reset form
            document.getElementById('gross').value = '';
            document.getElementById('tax_code').value = '1257L';
            document.getElementById('ni_category').value = 'A';
            document.getElementById('pensionToggle').checked = false;
            document.getElementById('pensionPercent').value = '';
            document.getElementById('studentLoanToggle').checked = false;
            document.getElementById('pensionInput').style.display = 'none';
            
            // Hide results
            const resultsCard = document.getElementById('payeResults');
            resultsCard.classList.remove('show-results');
            setTimeout(() => {
                resultsCard.style.display = 'none';
            }, 300);
            
            // Reset to monthly frequency
            document.getElementById('monthly').checked = true;
            
            const accordionItem = document.querySelector('.accordion .accordion-item');
            if (accordionItem) accordionItem.classList.remove('open');
            
            // Focus on salary input
            document.getElementById('gross').focus();
        },
        
        initializeCarousel: function() {
            const carouselTrack = document.getElementById('carouselTrack');
            const slides = document.querySelectorAll('.service-slide');
            
            if (!carouselTrack || slides.length === 0) return;
            
            // Calculate total width of all slides
            const slideWidth = slides[0].offsetWidth;
            const totalSlides = slides.length / 2; // We have duplicated slides
            const totalWidth = slideWidth * totalSlides;
            
            // Set animation duration based on total width
            const animationDuration = totalWidth / 30; // pixels per second
            
            // Set CSS variables for animation
            carouselTrack.style.setProperty('--slide-width', `${slideWidth}px`);
            carouselTrack.style.setProperty('--total-slides', totalSlides);
            carouselTrack.style.setProperty('--animation-duration', `${animationDuration}s`);
            
            // Pause animation on hover
            const carouselContainer = document.querySelector('.carousel-container');
            if (carouselContainer) {
                carouselContainer.addEventListener('mouseenter', () => {
                    carouselTrack.style.animationPlayState = 'paused';
                });
                
                carouselContainer.addEventListener('mouseleave', () => {
                    carouselTrack.style.animationPlayState = 'running';
                });
            }
            
            // Handle window resize
            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    const newSlideWidth = slides[0].offsetWidth;
                    const newTotalWidth = newSlideWidth * totalSlides;
                    const newAnimationDuration = newTotalWidth / 30;
                    
                    carouselTrack.style.setProperty('--slide-width', `${newSlideWidth}px`);
                    carouselTrack.style.setProperty('--animation-duration', `${newAnimationDuration}s`);
                }, 250);
            });
        }
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        Marsal.initializeCalculator();
    });
  </script>
</Layout>
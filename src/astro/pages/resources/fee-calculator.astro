---
import "../../../styles/pages/resources/fee-calculator.css";
import "../../../styles/themes/tools.css";  // Green theme for resources pages
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactUs from "../../components/ContactUs.astro";
---

<BaseLayout title="Fee Calculator – Instant Quote" theme="resources">
  <div class="fee-calculator-wrapper">
    <!-- === CALCULATOR FORM – FULL WIDTH (sidebar removed) === -->
    <div class="container">
      <div class="row">
        <div class="col-sm-12">
          <h2>Fees Calculator</h2>
          <div class="divider-content"></div>
          <br />

          <form id="quoteForm">
            <!-- Form container – now uses theme‑aware class -->
            <div class="calculator-form-container">
              
              <!-- Business type -->
              <div id="businesstype-group" class="form-group">
                <div class="row">
                  <div class="col-sm-6">
                    <label for="businesstype">What type of legal entity are you ?</label>
                  </div>
                  <div class="col-sm-6">
                    <select id="businesstype" name="businesstype">
                      <option value="" disabled selected>-- Choose --</option>
                      <option value="Sole trader">Sole trader</option>
                      <option value="Partnership">Partnership</option>
                      <option value="Limited company">Limited company</option>
                    </select>
                  </div>
                </div>
              </div>

              <!-- Turnover -->
              <div id="turnover-group" class="form-group">
                <div class="row">
                  <div class="col-sm-6">
                    <label for="turnover">What is your annual turnover?</label>
                  </div>
                  <div class="col-sm-6">
                    <select id="turnover" name="turnover">
                      <option value="" disabled selected>-- Choose --</option>
                      <option value="£0k–£90k">£ 0k – £ 90k</option>
                      <option value="£91k–£99k">£ 91k – £ 99k</option>
                      <option value="£100k–£149k">£ 100k – £ 149k</option>
                      <option value="£150k–£249k">£ 150k – £ 249k</option>
                      <option value="£250k–£349k">£ 250k – £ 349k</option>
                      <option value="£350k–£499k">£ 350k – £ 499k</option>
                      <option value="£500k–£749k">£ 500k – £ 749k</option>
                      <option value="£750k–£999k">£ 750k – £ 999k</option>
                    </select>
                  </div>
                </div>
              </div>

              <!-- Accounts & Tax Returns -->
              <div id="accounts-group" class="form-group">
                <div class="row">
                  <div class="col-sm-6">
                    <label>Do you require Accounts & Tax Returns services?</label>
                  </div>
                  <div class="col-sm-6">
                    <input type="radio" id="accountsyes" name="accounts" value="Yes" />
                    <label for="accountsyes">Yes</label>
                    <input type="radio" id="accountsno" name="accounts" value="No" />
                    <label for="accountsno">No</label>
                  </div>
                </div>
              </div>

              <!-- VAT -->
              <div id="vat-group" class="form-group">
                <div class="row">
                  <div class="col-sm-6">
                    <label>Do you require VAT services?</label>
                  </div>
                  <div class="col-sm-6">
                    <input type="radio" id="vatyes" name="vat" value="Yes" />
                    <label for="vatyes">Yes</label>
                    <input type="radio" id="vatno" name="vat" value="No" />
                    <label for="vatno">No</label>
                  </div>
                </div>
              </div>

              <!-- Payroll -->
              <div id="payroll-group" class="form-group">
                <div class="row">
                  <div class="col-sm-6">
                    <label>Do you require Payroll services?</label>
                  </div>
                  <div class="col-sm-6">
                    <input type="radio" id="payrollyes" name="payroll" value="Yes" />
                    <label for="payrollyes">Yes</label>
                    <input type="radio" id="payrollno" name="payroll" value="No" />
                    <label for="payrollno">No</label>
                  </div>
                </div>
              </div>

              <!-- Payroll type (hidden initially) -->
              <div id="payrolltype-group" class="form-group" style="display:none;">
                <div class="row">
                  <div class="col-sm-6">
                    <label>Weekly or Monthly Payroll?</label>
                  </div>
                  <div class="col-sm-6">
                    <input type="radio" id="payrollweek" name="payrolltype" value="Weekly" />
                    <label for="payrollweek">Weekly</label>
                    <input type="radio" id="payrollmonth" name="payrolltype" value="Monthly" />
                    <label for="payrollmonth">Monthly</label>
                  </div>
                </div>
              </div>

              <!-- Employees (hidden initially) -->
              <div id="employees-group" class="form-group" style="display:none;">
                <div class="row">
                  <div class="col-sm-6">
                    <label for="employees">How many employees do you have?</label>
                  </div>
                  <div class="col-sm-6">
                    <select id="employees" name="employees">
                      <option value="" disabled selected>-- Choose --</option>
                      <option value="1-5">1-5</option>
                      <option value="6-10">6-10</option>
                      <option value="11-15">11-15</option>
                      <option value="16-20">16-20</option>
                      <option value="21-30">21-30</option>
                      <option value="31-40">31-40</option>
                      <option value="41-50">41-50</option>
                      <option value="51-75">51-75</option>
                      <option value="76-100">76-100</option>
                    </select>
                  </div>
                </div>
              </div>

              <!-- Workplace Pensions (hidden initially) -->
              <div id="pensions-group" class="form-group" style="display:none;">
                <div class="row">
                  <div class="col-sm-6">
                    <label>With or without Work Place Pensions?</label>
                  </div>
                  <div class="col-sm-6">
                    <input type="radio" id="pensionswith" name="pensions" value="With" />
                    <label for="pensionswith">With</label>
                    <input type="radio" id="pensionswo" name="pensions" value="Without" />
                    <label for="pensionswo">Without</label>
                  </div>
                </div>
              </div>

              <br />

              <!-- Get Quote button – now uses theme‑aware class -->
              <div class="row">
                <div class="col-sm-12">
                  <center>
                    <button type="button" id="getQuoteButton" class="btn-calculate">
                      Get Quote
                    </button>
                  </center>
                </div>
              </div>

              <br />

              <!-- Quote results (hidden divs) -->
              <div class="row">
                <div class="col-sm-12">
                  <div id="AccountsQuote" style="display:none">£ 0</div>
                  <div id="VatQuote" style="display:none">£ 0</div>
                  <div id="PayrollQuote" style="display:none">£ 0</div>
                  <div id="PayrollPensionQuote" style="display:none">£ 0</div>
                  <center>
                    <h4 id="TotalQuote"></h4>
                  </center>
                </div>
              </div>

              <br />

              <!-- Additional messages -->
              <div id="msg">
                <center>
                  <h5>Our <span style="font-size:18px;">Personal Tax Return</span> only clients fees start from <span style="font-size:18px;">£175</span> ex vat</h5>
                  <br />
                  <h5>
                    You can call on &nbsp;<span style="font-size:18px;"><a href="tel:07468 641272">074-6864-1272</a></span>
                    &nbsp;for a fixed fee quote and organise a meeting with our consultant
                  </h5>
                </center>
              </div>

              <br />
              <p>
                Note: If your annual turnover is £ 1m + or for payroll services number of employees is 100+, then call us on
                <a href="tel:07468 641272">074-6864-1272.</a>
              </p>
            </div>
          </form>
        </div><!-- /.col-sm-12 -->
      </div><!-- /.row -->
    </div><!-- /.container -->
  </div>

  <!-- SERVICES CAROUSEL (unchanged) -->
  <section class="services-carousel-section">
    <h2 class="carousel-heading">Explore Our Services</h2>
    <div class="section-divider"></div>
    <div class="carousel-container">
      <div class="carousel-track" id="carouselTrack">
        <!-- Original Set of Slides -->
        <div class="service-slide">
          <img src="/icons/icons/accounts-icon.png" alt="Accounting Services">
          <h4><a href="/services/accounting/">Accounting Services</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/bookkeeping-icon.png" alt="Bookkeeping Services">
          <h4><a href="/services/bookkeeping/">Bookkeeping Services</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/mngt-accounts-icon.png" alt="Management Accounts">
          <h4><a href="/services/management-accounts/">Management Accounts</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/payroll-services-icon.png" alt="Payroll Services">
          <h4><a href="/services/payroll/">Payroll Services</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/property-accounts-icon.png" alt="Property Accounts">
          <h4><a href="/services/property-accounts/">Property Accounts</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/self-assessment-tax-returns-icon.png" alt="Self Assessment">
          <h4><a href="/services/self-assessment-tax-returns/">Self Assessment</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/starting-new-business-icon.png" alt="Marsal Business Launchpad">
          <h4><a href="/services/marsal-business-launchpad/">Marsal Business Launchpad</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/tax-investigation-icon.png" alt="Tax Investigation">
          <h4><a href="/services/tax-investigation/">Tax Investigation</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/value-added-icon.png" alt="VAT Services">
          <h4><a href="/services/vat/">VAT Services</a></h4>
        </div>
        
        <!-- Duplicate Set for Seamless Loop -->
        <div class="service-slide">
          <img src="/icons/icons/accounts-icon.png" alt="Accounting Services">
          <h4><a href="/services/accounting/">Accounting Services</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/bookkeeping-icon.png" alt="Bookkeeping Services">
          <h4><a href="/services/bookkeeping/">Bookkeeping Services</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/mngt-accounts-icon.png" alt="Management Accounts">
          <h4><a href="/services/management-accounts/">Management Accounts</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/payroll-services-icon.png" alt="Payroll Services">
          <h4><a href="/services/payroll/">Payroll Services</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/property-accounts-icon.png" alt="Property Accounts">
          <h4><a href="/services/property-accounts/">Property Accounts</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/self-assessment-tax-returns-icon.png" alt="Self Assessment">
          <h4><a href="/services/self-assessment-tax-returns/">Self Assessment</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/starting-new-business-icon.png" alt="Marsal Business Launchpad">
          <h4><a href="/services/marsal-business-launchpad/">Marsal Business Launchpad</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/tax-investigation-icon.png" alt="Tax Investigation">
          <h4><a href="/services/tax-investigation/">Tax Investigation</a></h4>
        </div>
        <div class="service-slide">
          <img src="/icons/icons/value-added-icon.png" alt="VAT Services">
          <h4><a href="/services/vat/">VAT Services</a></h4>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Us component (optional) -->
  <ContactUs />

  <!-- === CLIENT‑SIDE JAVASCRIPT (modernised) === -->
 <script client:load>
  (function() {
    "use strict";

    // ----- CORRECTED FEE DATA (based on your tables) -----
    const feeData = {
      accounts: {
        "£0k–£90k":   { "Sole trader": 680, "Partnership": 680, "Limited company": 850 },
        "£91k–£99k":  { "Sole trader": 830, "Partnership": 830, "Limited company": 950 },
        "£100k–£149k":{ "Sole trader": 880, "Partnership": 880, "Limited company": 1080 },
        "£150k–£249k":{ "Sole trader": 980, "Partnership": 980, "Limited company": 1230 },
        "£250k–£349k":{ "Sole trader": 1280, "Partnership": 1280, "Limited company": 1480 },
        "£350k–£499k":{ "Sole trader": 1380, "Partnership": 1380, "Limited company": 1580 },
        "£500k–£749k":{ "Sole trader": 1580, "Partnership": 1580, "Limited company": 1780 },
        "£750k–£999k":{ "Sole trader": 1780, "Partnership": 1780, "Limited company": 1980 },
        "£1m+": "Negotiable"
      },
      vat: {
        // Both low ranges map to the same £0–99k fee
        "£0k–£90k":   525,
        "£91k–£99k":  525,
        "£100k–£149k":700,
        "£150k–£249k":830,
        "£250k–£349k":930,
        "£350k–£499k":1130,
        "£500k–£749k":1580,
        "£750k–£999k":1880,
        "£1m+": "Negotiable"
      },
      payroll: {
        "1-5":   { Weekly: 520, Monthly: 350 },
        "6-10":  { Weekly: 700, Monthly: 600 },
        "11-15": { Weekly: 850, Monthly: 750 },
        "16-20": { Weekly: 950, Monthly: 875 },
        "21-30": { Weekly: 1050, Monthly: 950 },
        "31-40": { Weekly: 1475, Monthly: 1350 },
        "41-50": { Weekly: 1775, Monthly: 1650 },
        "51-75": { Weekly: 2750, Monthly: 2500 },
        "76-100":{ Weekly: 3150, Monthly: 2900 },
        "100+": "Negotiable"
      },
      pensions: {
        "1-5":   { Weekly: 180, Monthly: 75 },
        "6-10":  { Weekly: 195, Monthly: 115 },
        "11-15": { Weekly: 235, Monthly: 145 },
        "16-20": { Weekly: 270, Monthly: 175 },
        "21-30": { Weekly: 365, Monthly: 200 },
        "31-40": { Weekly: 465, Monthly: 245 },
        "41-50": { Weekly: 550, Monthly: 275 },
        "51-75": { Weekly: 650, Monthly: 310 },
        "76-100":{ Weekly: 740, Monthly: 350 },
        "100+": "Negotiable"
      }
    };

    // ----- DOM ELEMENTS (unchanged) -----
    const businessType = document.getElementById('businesstype');
    const turnover = document.getElementById('turnover');
    const employees = document.getElementById('employees');
    const accountsRadios = document.getElementsByName('accounts');
    const vatRadios = document.getElementsByName('vat');
    const payrollRadios = document.getElementsByName('payroll');
    const payrollTypeRadios = document.getElementsByName('payrolltype');
    const pensionsRadios = document.getElementsByName('pensions');

    const payrollTypeGroup = document.getElementById('payrolltype-group');
    const employeesGroup = document.getElementById('employees-group');
    const pensionsGroup = document.getElementById('pensions-group');

    const accountsQuote = document.getElementById('AccountsQuote');
    const vatQuote = document.getElementById('VatQuote');
    const payrollQuote = document.getElementById('PayrollQuote');
    const pensionQuote = document.getElementById('PayrollPensionQuote');
    const totalQuote = document.getElementById('TotalQuote');

    const getQuoteBtn = document.getElementById('getQuoteButton');

    // ----- TOGGLE PAYROLL FIELDS -----
    function togglePayrollFields(show) {
      payrollTypeGroup.style.display = show ? 'block' : 'none';
      employeesGroup.style.display = show ? 'block' : 'none';
      pensionsGroup.style.display = show ? 'block' : 'none';
    }

    payrollRadios.forEach(radio => {
      radio.addEventListener('change', function(e) {
        togglePayrollFields(e.target.value === 'Yes');
      });
    });

    // ----- VALIDATION -----
    function validateForm() {
      if (!businessType.value) {
        alert('Please select a business type');
        return false;
      }
      if (!turnover.value) {
        alert('Please select a turnover range');
        return false;
      }
      if (!document.querySelector('input[name="accounts"]:checked')) {
        alert('Please select an option for Accounts & Tax Returns');
        return false;
      }
      if (!document.querySelector('input[name="vat"]:checked')) {
        alert('Please select an option for VAT services');
        return false;
      }
      if (!document.querySelector('input[name="payroll"]:checked')) {
        alert('Please select an option for Payroll services');
        return false;
      }

      const payrollValue = document.querySelector('input[name="payroll"]:checked')?.value;
      if (payrollValue === 'Yes') {
        if (!document.querySelector('input[name="payrolltype"]:checked')) {
          alert('Please select Weekly or Monthly Payroll');
          return false;
        }
        if (!employees.value) {
          alert('Please select number of employees');
          return false;
        }
        if (!document.querySelector('input[name="pensions"]:checked')) {
          alert('Please select With or Without Workplace Pensions');
          return false;
        }
      }
      return true;
    }

    // ----- CALCULATE QUOTE -----
    function calculateQuote() {
      accountsQuote.style.display = 'none';
      vatQuote.style.display = 'none';
      payrollQuote.style.display = 'none';
      pensionQuote.style.display = 'none';

      const bizType = businessType.value;
      const turn = turnover.value;
      const accountsYes = document.querySelector('input[name="accounts"]:checked')?.value === 'Yes';
      const vatYes = document.querySelector('input[name="vat"]:checked')?.value === 'Yes';
      const payrollYes = document.querySelector('input[name="payroll"]:checked')?.value === 'Yes';

      let total = 0;

      if (accountsYes) {
        let fee = feeData.accounts[turn]?.[bizType];
        if (fee === 'Negotiable' || fee === undefined) {
          accountsQuote.innerText = 'Negotiable';
          accountsQuote.style.display = 'block';
        } else {
          accountsQuote.innerText = `£ ${fee}`;
          accountsQuote.style.display = 'block';
          total += fee;
        }
      }

      if (vatYes) {
        let fee = feeData.vat[turn];
        if (fee === 'Negotiable' || fee === undefined) {
          vatQuote.innerText = 'Negotiable';
          vatQuote.style.display = 'block';
        } else {
          vatQuote.innerText = `£ ${fee}`;
          vatQuote.style.display = 'block';
          total += fee;
        }
      }

      if (payrollYes) {
        const emp = employees.value;
        const payrollType = document.querySelector('input[name="payrolltype"]:checked')?.value;
        const pensionChoice = document.querySelector('input[name="pensions"]:checked')?.value;

        if (emp && payrollType) {
          let payrollFee = feeData.payroll[emp]?.[payrollType];
          if (payrollFee === 'Negotiable' || payrollFee === undefined) {
            payrollQuote.innerText = 'Negotiable';
            payrollQuote.style.display = 'block';
          } else {
            payrollQuote.innerText = `£ ${payrollFee}`;
            payrollQuote.style.display = 'block';
            total += payrollFee;
          }

          if (pensionChoice === 'With') {
            let pensionFee = feeData.pensions[emp]?.[payrollType];
            if (pensionFee === 'Negotiable' || pensionFee === undefined) {
              pensionQuote.innerText = 'Negotiable';
              pensionQuote.style.display = 'block';
            } else {
              pensionQuote.innerText = `£ ${pensionFee}`;
              pensionQuote.style.display = 'block';
              total += pensionFee;
            }
          }
        }
      }

      totalQuote.innerText = total > 0 ? `Estimated Total: £ ${total}` : 'Please complete all selections';
    }

    getQuoteBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (validateForm()) {
        calculateQuote();
      }
    });

    togglePayrollFields(false);
  })();
</script>